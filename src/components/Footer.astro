<footer class="relative mx-auto max-w-7xl px-6 pb-6">
  <div class="flex w-full flex-col items-center justify-between gap-4 rounded-2xl border border-border/70 px-6 py-5 text-sm text-muted-foreground backdrop-blur-xl sm:flex-row">
    
    <div>
      <p class="inline-flex items-center gap-1.5">
        <i class="fa-solid fa-code text-muted-foreground/80" aria-hidden="true"></i>
        Made with
        <button
          type="button"
          id="love-burst-button"
          class="relative inline-flex h-5 w-5 items-center justify-center rounded-full text-rose-600 transition-colors hover:text-rose-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/70"
          aria-label="Explosión de corazones"
        >
          <i class="fa-solid fa-heart pointer-events-none" aria-hidden="true"></i>
        </button>
        by
        <a class="text-foreground/85 transition-colors hover:text-foreground" href="https://github.com/bviron" target="_blank" rel="noreferrer">
          @bviron
        </a>
      </p>
      <p class="text-left text-xs text-muted-foreground/80">
        v2026.03.02-20:50
      </p>
    </div>

    <div class="inline-flex items-center gap-2">
      <a
        href="https://github.com/bviron"
        target="_blank"
        rel="noreferrer"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border/70 bg-background/40 text-muted-foreground transition hover:bg-accent hover:text-foreground"
        aria-label="GitHub"
      >
        <i class="fa-brands fa-github" aria-hidden="true"></i>
      </a>
      <div class="relative inline-flex">
        <button
          type="button"
          id="copy-discord-user"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border/70 bg-background/40 text-muted-foreground transition hover:bg-accent hover:text-foreground"
          aria-label="Copiar usuario de Discord"
          title="Copiar @bviron"
        >
          <i class="fa-brands fa-discord" aria-hidden="true"></i>
        </button>
        <span
          id="copy-discord-popover"
          role="status"
          aria-live="polite"
          class="pointer-events-none absolute bottom-full left-1/2 mb-2 -translate-x-1/2 rounded-md border border-border/70 bg-popover/95 px-2 py-1 text-xs text-popover-foreground opacity-0 transition-opacity duration-200"
        >
          Copiado
        </span>
      </div>
    </div>
  </div>
</footer>

<script>
  const discordButton = document.getElementById('copy-discord-user');
  const discordPopover = document.getElementById('copy-discord-popover');
  let popoverTimer: number | undefined;

  const showPopover = (message: string | null) => {
    if (!discordPopover) return;
    discordPopover.textContent = message;
    discordPopover.classList.remove('opacity-0');
    discordPopover.classList.add('opacity-100');

    if (popoverTimer) clearTimeout(popoverTimer);
    popoverTimer = setTimeout(() => {
      discordPopover.classList.remove('opacity-100');
      discordPopover.classList.add('opacity-0');
    }, 1600);
  };

  discordButton?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('@bviron');
      showPopover('Copiado');
    } catch {
      // Fallback for contexts where Clipboard API is unavailable.
      const tempInput = document.createElement('input');
      tempInput.value = '@bviron';
      document.body.appendChild(tempInput);
      tempInput.select();
      const copied = document.execCommand('copy');
      document.body.removeChild(tempInput);
      showPopover(copied ? 'Copiado' : 'No se pudo copiar');
    }
  });

  const loveBurstButton = document.getElementById('love-burst-button');

  const burstHearts = () => {
    if (!loveBurstButton) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const particles = 14;
    for (let i = 0; i < particles; i += 1) {
      const particle = document.createElement('span');
      const angle = (Math.PI * 2 * i) / particles + Math.random() * 0.35;
      const distance = 18 + Math.random() * 26;
      const dx = `${Math.cos(angle) * distance}px`;
      const dy = `${Math.sin(angle) * distance}px`;
      const rotate = `${Math.random() * 70 - 35}deg`;
      const duration = `${520 + Math.random() * 320}ms`;
      const size = `${0.6 + Math.random() * 0.45}rem`;

      particle.className = 'heart-burst-particle';
      particle.textContent = '♥';
      particle.style.setProperty('--dx', dx);
      particle.style.setProperty('--dy', dy);
      particle.style.setProperty('--rot', rotate);
      particle.style.setProperty('--dur', duration);
      particle.style.setProperty('--size', size);

      loveBurstButton.appendChild(particle);
      particle.addEventListener('animationend', () => particle.remove(), { once: true });
    }
  };

  loveBurstButton?.addEventListener('click', burstHearts);
</script>

<style is:global>
  .heart-burst-particle {
    position: absolute;
    left: 50%;
    top: 50%;
    pointer-events: none;
    font-size: var(--size, 0.85rem);
    line-height: 1;
    color: rgb(244 63 94);
    opacity: 0.95;
    transform: translate(-50%, -50%) scale(1);
    animation: heart-burst var(--dur, 720ms) cubic-bezier(0.2, 0.85, 0.3, 1) forwards;
    will-change: transform, opacity;
  }

  @keyframes heart-burst {
    0% {
      opacity: 0.95;
      transform: translate(-50%, -50%) scale(0.8);
    }
    100% {
      opacity: 0;
      transform: translate(calc(-50% + var(--dx)), calc(-50% + var(--dy))) rotate(var(--rot)) scale(0.2);
    }
  }
</style>
